{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "changeforge.repository-context-pack.v3",
  "title": "ChangeForge TaskContextPack v3",
  "type": "object",
  "required": ["task_context_pack"],
  "properties": {
    "task_context_pack": {
      "type": "object",
      "required": [
        "schema_version",
        "task",
        "graph_source",
        "freshness",
        "context_control",
        "jit_retrieval_plan",
        "artifact_policy",
        "selected_files",
        "selected_graph_nodes",
        "skipped_graph_nodes",
        "closure_evidence",
        "assumptions",
        "selected_symbols",
        "caller_callee_edges",
        "imports",
        "references",
        "related_tests",
        "validation_candidates",
        "source_of_truth",
        "generated_artifacts",
        "ownership",
        "reuse_candidates",
        "rejected_locations",
        "anti_bloat_decision",
        "omitted_nodes",
        "residual_risk",
        "graph_validation_candidates"
      ],
      "properties": {
        "schema_version": {"const": 3},
        "task": {"type": "string"},
        "task_goal": {"type": "string"},
        "graph_source": {"type": "object"},
        "freshness": {"type": "object"},
        "changed_paths": {"type": "array", "items": {"type": "string"}},
        "context_control": {"type": "object"},
        "jit_retrieval_plan": {"type": "object"},
        "artifact_policy": {"type": "object"},
        "selected_files": {"type": "array"},
        "selected_graph_nodes": {"type": "array"},
        "skipped_graph_nodes": {"type": "array"},
        "closure_evidence": {"type": "array"},
        "assumptions": {"type": "array"},
        "selected_symbols": {"type": "array"},
        "caller_callee_edges": {"type": "array"},
        "imports": {"type": "array"},
        "references": {"type": "array"},
        "related_tests": {"type": "array"},
        "validation_candidates": {"type": "array"},
        "source_of_truth": {"type": "array"},
        "generated_artifacts": {"type": "array"},
        "ownership": {"type": "array"},
        "reuse_candidates": {"type": "array"},
        "rejected_locations": {"type": "array"},
        "anti_bloat_decision": {"type": "object"},
        "omitted_nodes": {"type": "array"},
        "residual_risk": {"type": "array"},
        "graph_validation_candidates": {"type": "array"}
      }
    }
  }
}
