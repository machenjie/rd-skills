{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "changeforge.repository-graph.v2",
  "title": "ChangeForge RepositoryGraph v2",
  "type": "object",
  "required": ["repository_graph"],
  "properties": {
    "repository_graph": {
      "type": "object",
      "required": [
        "schema_version",
        "repo_hash",
        "commit_sha",
        "created_at",
        "files",
        "symbols",
        "edges",
        "module_boundaries",
        "ownership",
        "generated_artifacts",
        "validation_candidates",
        "freshness"
      ],
      "properties": {
        "schema_version": {"const": 2},
        "repo_hash": {"type": "string"},
        "artifact_hash": {"type": "string"},
        "commit_sha": {"type": ["string", "null"]},
        "created_at": {"type": "string"},
        "indexed_at": {"type": "string"},
        "indexed_commit": {"type": ["string", "null"]},
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "kind", "role", "symbols", "references", "evidence", "source_hash", "freshness", "confidence", "extractor"]
          }
        },
        "symbols": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "kind", "path", "line", "visibility", "language", "confidence", "evidence", "source_hash", "freshness", "extractor"],
            "properties": {
              "name": {"type": "string"},
              "kind": {
                "enum": ["function", "class", "method", "constant", "heading", "config_key", "unknown"]
              },
              "path": {"type": "string"},
              "line": {"type": ["integer", "number", "string"]},
              "visibility": {"type": "string"},
              "owner_object": {},
              "parent_symbol": {},
              "language": {"type": "string"},
              "confidence": {"type": "string"},
              "freshness": {"type": "string"},
              "extractor": {"type": "string"},
              "source_hash": {"type": ["string", "null"]},
              "evidence": {"type": "object"}
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to", "type", "edge_type", "evidence", "confidence", "freshness", "extractor"],
            "properties": {
              "from": {"type": "string"},
              "to": {"type": "string"},
              "type": {"type": "string"},
              "edge_type": {
                "type": "string",
                "enum": [
                  "imports",
                  "calls",
                  "references",
                  "tests",
                  "owns",
                  "generates",
                  "generated_from",
                  "depends_on",
                  "object_defined_in",
                  "rule_enforced_by",
                  "rule_previewed_by",
                  "rule_defended_by",
                  "workflow_transition_implemented_by",
                  "event_produced_by",
                  "event_consumed_by",
                  "golden_case_validates",
                  "memory_warns_about",
                  "unknown"
                ]
              },
              "evidence": {"type": "object"},
              "confidence": {"type": "string"},
              "freshness": {"type": "string"},
              "extractor": {
                "type": "string",
                "enum": [
                  "python_symbol_extractor",
                  "markdown_reference_extractor",
                  "yaml_reference_extractor",
                  "file_heuristic",
                  "import_graph",
                  "test_graph",
                  "generated_artifact_graph",
                  "reference_graph",
                  "business_semantic_graph",
                  "validation_broker.command_registry",
                  "unknown"
                ]
              }
            }
          }
        },
        "module_boundaries": {"type": "array"},
        "ownership": {"type": "array"},
        "generated_artifacts": {"type": "array"},
        "validation_candidates": {"type": "array"},
        "freshness": {"type": "object"}
      }
    }
  }
}
