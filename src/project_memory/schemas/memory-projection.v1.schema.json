{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://changeforge.dev/schemas/project-memory/memory-projection.v1.schema.json",
  "title": "ChangeForge Project Memory Projection",
  "description": "Deterministic retrieval projection over bounded memory events. It is advisory evidence and always requires source inspection before acting.",
  "type": "object",
  "additionalProperties": false,
  "required": ["project_memory_projection"],
  "properties": {
    "project_memory_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "retrieval_key",
        "included_events",
        "excluded_events",
        "summary",
        "source_check_required",
        "stale_context_gate",
        "residual_risk"
      ],
      "$defs": {
        "boundedList": {
          "type": "array",
          "maxItems": 50,
          "items": { "type": "object" }
        },
        "boundedStringList": {
          "type": "array",
          "maxItems": 50,
          "items": { "type": "string", "maxLength": 300 }
        }
      },
      "properties": {
        "schema_version": { "const": 1 },
        "retrieval_key": { "type": "string", "minLength": 1, "maxLength": 80 },
        "included_events": { "$ref": "#/properties/project_memory_projection/$defs/boundedList" },
        "excluded_events": { "$ref": "#/properties/project_memory_projection/$defs/boundedList" },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "fragile_files",
            "repeat_failures",
            "validation_hints",
            "review_patterns",
            "business_memory"
          ],
          "properties": {
            "fragile_files": { "$ref": "#/properties/project_memory_projection/$defs/boundedList" },
            "repeat_failures": { "$ref": "#/properties/project_memory_projection/$defs/boundedList" },
            "validation_hints": { "$ref": "#/properties/project_memory_projection/$defs/boundedList" },
            "review_patterns": { "$ref": "#/properties/project_memory_projection/$defs/boundedList" },
            "business_memory": {
              "type": "object",
              "additionalProperties": false,
              "required": ["accepted", "rejected", "stale", "not_verified"],
              "properties": {
                "accepted": { "$ref": "#/properties/project_memory_projection/$defs/boundedList" },
                "rejected": { "$ref": "#/properties/project_memory_projection/$defs/boundedList" },
                "stale": { "$ref": "#/properties/project_memory_projection/$defs/boundedList" },
                "not_verified": { "$ref": "#/properties/project_memory_projection/$defs/boundedList" }
              }
            }
          }
        },
        "source_check_required": { "type": "boolean", "const": true },
        "stale_context_gate": { "type": "string", "enum": ["pass", "warn", "block"] },
        "residual_risk": { "$ref": "#/properties/project_memory_projection/$defs/boundedStringList" }
      }
    }
  }
}
