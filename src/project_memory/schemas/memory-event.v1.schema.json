{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://changeforge.dev/schemas/project-memory/memory-event.v1.schema.json",
  "title": "ChangeForge Project Memory Event",
  "description": "Append-only bounded project memory fact. It must not contain raw prompts, environment variables, secrets, full command output, or absolute user paths.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "repo_hash",
    "commit_sha",
    "timestamp",
    "kind",
    "bounded_paths",
    "summary",
    "privacy_class",
    "retention_policy",
    "source",
    "task_fingerprint",
    "type",
    "paths",
    "symbols",
    "owner_skill",
    "reviewer_skill",
    "route_manifest_hash",
    "outcome",
    "evidence_refs",
    "confidence",
    "promotion_status",
    "created_at"
  ],
  "$defs": {
    "boundedStringList": {
      "type": "array",
      "maxItems": 50,
      "items": { "type": "string", "maxLength": 300 }
    },
    "boundedPathList": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "string",
        "maxLength": 200,
        "not": { "pattern": "^(/|~|\\.\\.)" }
      }
    }
  },
  "properties": {
    "schema_version": { "const": 1 },
    "event_id": { "type": "string", "minLength": 1, "maxLength": 300, "pattern": "^mem_" },
    "repo_hash": { "type": "string", "minLength": 1, "maxLength": 300 },
    "commit_sha": { "type": "string", "maxLength": 300 },
    "timestamp": { "type": "string", "maxLength": 80 },
    "kind": {
      "type": "string",
      "enum": [
        "fragile_file",
        "repeat_failure",
        "validation_pattern",
        "review_finding_pattern",
        "module_convention",
        "generated_source_mapping",
        "route_correction",
        "false_positive_hook",
        "false_negative_hook"
      ]
    },
    "bounded_paths": { "$ref": "#/$defs/boundedPathList" },
    "summary": { "type": "string", "maxLength": 240 },
    "privacy_class": {
      "type": "string",
      "enum": ["safe_bounded", "redacted", "rejected_sensitive"]
    },
    "retention_policy": { "type": "string", "minLength": 1, "maxLength": 300 },
    "source": {
      "type": "string",
      "enum": ["telemetry", "trajectory", "human", "validator"]
    },
    "task_fingerprint": { "type": "string", "minLength": 1, "maxLength": 300 },
    "type": {
      "type": "string",
      "enum": [
        "route_decision",
        "context_pack",
        "implementation_attempt",
        "validation_result",
        "review_finding",
        "repair_attempt",
        "accepted_decision",
        "rejected_decision",
        "fragile_file",
        "validated_command",
        "hook_false_positive",
        "hook_false_negative",
        "repeat_failure"
      ]
    },
    "paths": { "$ref": "#/$defs/boundedPathList" },
    "symbols": { "$ref": "#/$defs/boundedStringList" },
    "owner_skill": { "type": "string", "maxLength": 300 },
    "reviewer_skill": { "type": "string", "maxLength": 300 },
    "route_manifest_hash": { "type": "string", "maxLength": 300 },
    "outcome": {
      "type": "string",
      "enum": ["success", "failed", "partial", "blocked", "unknown"]
    },
    "evidence_refs": { "$ref": "#/$defs/boundedStringList" },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "promotion_status": {
      "type": "string",
      "enum": ["raw", "candidate", "approved", "rejected"]
    },
    "created_at": { "type": "string", "maxLength": 80 }
  }
}
