{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_compaction_snapshot.py\"",
            "timeout": 10,
            "statusMessage": "Snapshotting ChangeForge compacted context"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_session_bootstrap.py\"",
            "timeout": 10,
            "statusMessage": "Loading ChangeForge route preflight"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_compaction_reinject.py\"",
            "timeout": 10,
            "statusMessage": "Reinjecting ChangeForge compacted context"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_professional_injector.py\"",
            "timeout": 10,
            "statusMessage": "Injecting ChangeForge professional context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_user_prompt_route_reminder.py\"",
            "timeout": 10,
            "statusMessage": "Adding ChangeForge route reminder"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_professional_injector.py\"",
            "timeout": 10,
            "statusMessage": "Classifying ChangeForge action stage"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_sdd_material_choice_gate.py\"",
            "timeout": 10,
            "statusMessage": "Checking ChangeForge SDD material choice"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_review_gate.py\"",
            "timeout": 10,
            "statusMessage": "Checking ChangeForge review intent"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "apply_patch|Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_professional_injector.py\"",
            "timeout": 10,
            "statusMessage": "Injecting ChangeForge action context"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_sdd_material_choice_gate.py\"",
            "timeout": 10,
            "statusMessage": "Checking ChangeForge SDD material choice"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_pre_edit_structure_gate.py\"",
            "timeout": 10,
            "statusMessage": "Checking ChangeForge implementation preflight"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_pre_tool_risk_preview.py\"",
            "timeout": 10,
            "statusMessage": "Previewing ChangeForge risk surface"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_permission_policy_gate.py\"",
            "timeout": 10,
            "statusMessage": "Checking ChangeForge permission policy"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_permission_policy_gate.py\"",
            "timeout": 10,
            "statusMessage": "Checking ChangeForge permission policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write|MultiEdit|Bash|Read|Grep|Glob|LS|Search|View|Open|Fetch|fetch_file|fetch_pr_patch|get_pr_diff|MCP|GitHub|mcp__filesystem__read_file|mcp__filesystem__list_directory|mcp__github__get_file_contents|mcp__github__pull_request_read|mcp__github__search_code|mcpfilesystemreadfile|mcpfilesystemlistdirectory|mcpgithubgetfilecontents|mcpgithubpullrequestread|mcpgithubsearchcode",
        "hooks": [
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_professional_injector.py\"",
            "timeout": 10,
            "statusMessage": "Updating ChangeForge action context"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_read_context_gate.py\"",
            "timeout": 10,
            "statusMessage": "Recording ChangeForge read context"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_tool_output_boundary_gate.py\"",
            "timeout": 10,
            "statusMessage": "Recording ChangeForge tool output boundary"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_review_gate.py\"",
            "timeout": 10,
            "statusMessage": "Checking ChangeForge review closure"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_post_edit_structure_gate.py\"",
            "timeout": 10,
            "statusMessage": "Checking ChangeForge structure, naming, reuse, and comment gate"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_risk_surface_gate.py\"",
            "timeout": 10,
            "statusMessage": "Checking ChangeForge risk surface gate"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_session_bootstrap.py\"",
            "timeout": 10,
            "statusMessage": "Loading ChangeForge route preflight for subagent"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_professional_injector.py\"",
            "timeout": 10,
            "statusMessage": "Injecting ChangeForge subagent context"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_subagent_skill_contract.py\"",
            "timeout": 10,
            "statusMessage": "Injecting ChangeForge subagent contract"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_subagent_stop_reminder.py\"",
            "timeout": 10,
            "statusMessage": "Checking ChangeForge subagent closure"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_sdd_material_choice_gate.py\"",
            "timeout": 10,
            "statusMessage": "Checking ChangeForge SDD material choice"
          },
          {
            "type": "command",
            "command": "CHANGEFORGE_AGENT=codex /usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/changeforge_stop_closure_gate.py\"",
            "timeout": 10,
            "statusMessage": "Checking ChangeForge closure gate"
          }
        ]
      }
    ]
  }
}
