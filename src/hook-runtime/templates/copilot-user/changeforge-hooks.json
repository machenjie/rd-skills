{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "CHANGEFORGE_AGENT=copilot /usr/bin/env python3 \"${HOME}/.copilot/hooks/changeforge/changeforge_compaction_snapshot.py\"",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "command": "CHANGEFORGE_AGENT=copilot /usr/bin/env python3 \"${HOME}/.copilot/hooks/changeforge/changeforge_session_bootstrap.py\"",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "command": "CHANGEFORGE_AGENT=copilot /usr/bin/env python3 \"${HOME}/.copilot/hooks/changeforge/changeforge_compaction_reinject.py\"",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "command": "CHANGEFORGE_AGENT=copilot /usr/bin/env python3 \"${HOME}/.copilot/hooks/changeforge/changeforge_professional_injector.py\"",
        "timeoutSec": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "CHANGEFORGE_AGENT=copilot /usr/bin/env python3 \"${HOME}/.copilot/hooks/changeforge/changeforge_professional_injector.py\"",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "command": "CHANGEFORGE_AGENT=copilot /usr/bin/env python3 \"${HOME}/.copilot/hooks/changeforge/changeforge_read_context_gate.py\"",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "command": "CHANGEFORGE_AGENT=copilot /usr/bin/env python3 \"${HOME}/.copilot/hooks/changeforge/changeforge_review_gate.py\"",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "command": "CHANGEFORGE_AGENT=copilot /usr/bin/env python3 \"${HOME}/.copilot/hooks/changeforge/changeforge_post_edit_structure_gate.py\"",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "command": "CHANGEFORGE_AGENT=copilot /usr/bin/env python3 \"${HOME}/.copilot/hooks/changeforge/changeforge_risk_surface_gate.py\"",
        "timeoutSec": 10
      }
    ],
    "SubagentStart": [
      {
        "type": "command",
        "command": "CHANGEFORGE_AGENT=copilot /usr/bin/env python3 \"${HOME}/.copilot/hooks/changeforge/changeforge_session_bootstrap.py\"",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "command": "CHANGEFORGE_AGENT=copilot /usr/bin/env python3 \"${HOME}/.copilot/hooks/changeforge/changeforge_professional_injector.py\"",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "command": "CHANGEFORGE_AGENT=copilot /usr/bin/env python3 \"${HOME}/.copilot/hooks/changeforge/changeforge_subagent_skill_contract.py\"",
        "timeoutSec": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "CHANGEFORGE_AGENT=copilot CHANGEFORGE_HOOK_MODE=block /usr/bin/env python3 \"${HOME}/.copilot/hooks/changeforge/changeforge_stop_closure_gate.py\"",
        "timeoutSec": 10
      }
    ]
  }
}
