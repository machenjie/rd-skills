{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://changeforge.dev/schemas/hook-state.v1.schema.json",
  "title": "ChangeForge Hook State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runtime",
    "changed_paths",
    "structure_findings",
    "structure_quality_findings",
    "risk_surfaces",
    "suggested_skills",
    "suggested_capabilities",
    "suggested_domain_extensions",
    "suggested_gates",
    "validation_command_seen",
    "validation_seen",
    "updated_at"
  ],
  "properties": {
    "runtime": {
      "type": "string",
      "enum": ["codex", "claude", "unknown"]
    },
    "changed_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "structure_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "file_naming_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reuse_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "extension_reuse_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "advanced_refactor_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "comment_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "structure_quality_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_surfaces": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "suggested_skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "suggested_capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "suggested_domain_extensions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "suggested_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_seen": {
      "description": "Backward-compatible alias for validation_command_seen.",
      "type": "boolean"
    },
    "validation_command_seen": {
      "description": "Whether a validation-looking command was observed this turn. This is not completion evidence without an outcome in the stop closure.",
      "type": "boolean"
    },
    "turn_id": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
