{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://changeforge.dev/schemas/hook-state.v1.schema.json",
  "title": "ChangeForge Hook State",
  "description": "Bounded per-turn hook state stored in the user cache. It must not contain prompt text, secrets, environment variables, full command output, or user-specific corpora.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runtime",
    "changed_paths",
    "risk_surfaces",
    "suggested_skills",
    "suggested_capabilities",
    "suggested_domain_extensions",
    "suggested_gates",
    "active_skill_context",
    "turn_stage",
    "owner_skill",
    "reviewer_skill",
    "validation_command_seen",
    "validation_seen",
    "event_index",
    "last_material_edit_index",
    "last_validation_command_index",
    "updated_at"
  ],
  "$defs": {
    "stringList": {
      "type": "array",
      "maxItems": 50,
      "items": { "type": "string", "maxLength": 300 }
    },
    "runtimeAdapter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "type": "string",
          "enum": ["codex", "claude", "copilot", "generic", "unknown", "cline", "roo", "openhands", "gemini-cli", "goose"]
        },
        "supported_checks": { "$ref": "#/$defs/stringList" },
        "unsupported_checks": { "$ref": "#/$defs/stringList" },
        "active_unsupported_checks": { "$ref": "#/$defs/stringList" },
        "required_unsupported_checks": { "$ref": "#/$defs/stringList" },
        "active_degradation": { "$ref": "#/$defs/stringList" },
        "degraded_capabilities": { "$ref": "#/$defs/stringList" },
        "degraded_checks": { "$ref": "#/$defs/stringList" },
        "fail_open_policy": { "type": "string", "maxLength": 300 },
        "fail_closed_allowed_checks": { "$ref": "#/$defs/stringList" },
        "visibility": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "read_paths": { "type": "string", "enum": ["none", "partial", "full"] },
            "changed_paths": { "type": "string", "enum": ["none", "partial", "full"] },
            "command_kind": { "type": "string", "enum": ["none", "partial", "full"] },
            "command_risk": { "type": "string", "enum": ["none", "partial", "full"] },
            "validation_outcome": { "type": "string", "enum": ["none", "partial", "full"] },
            "permission_decision": { "type": "string", "enum": ["none", "partial", "full"] },
            "rollback_checkpoint": { "type": "string", "enum": ["none", "partial", "full"] }
          }
        }
      }
    }
  },
  "properties": {
    "runtime": {
      "type": "string",
      "enum": ["codex", "claude", "copilot", "generic", "unknown", "cline", "roo", "openhands", "gemini-cli", "goose"]
    },
    "runtime_adapter": { "$ref": "#/$defs/runtimeAdapter" },
    "normalized_events": { "$ref": "#/$defs/stringList" },
    "changed_paths": { "$ref": "#/$defs/stringList" },
    "deleted_paths": { "$ref": "#/$defs/stringList" },
    "generated_paths": { "$ref": "#/$defs/stringList" },
    "read_paths": { "$ref": "#/$defs/stringList" },
    "read_tools": { "$ref": "#/$defs/stringList" },
    "searched_patterns": { "$ref": "#/$defs/stringList" },
    "external_file_changes": { "$ref": "#/$defs/stringList" },
    "config_changes": { "$ref": "#/$defs/stringList" },
    "structure_findings": { "$ref": "#/$defs/stringList" },
    "file_naming_findings": { "$ref": "#/$defs/stringList" },
    "reuse_findings": { "$ref": "#/$defs/stringList" },
    "extension_reuse_findings": { "$ref": "#/$defs/stringList" },
    "advanced_refactor_findings": { "$ref": "#/$defs/stringList" },
    "comment_findings": { "$ref": "#/$defs/stringList" },
    "structure_quality_findings": { "$ref": "#/$defs/stringList" },
    "post_edit_structure_findings": { "$ref": "#/$defs/stringList" },
    "review_targets": { "$ref": "#/$defs/stringList" },
    "review_findings": { "$ref": "#/$defs/stringList" },
    "repair_findings": { "$ref": "#/$defs/stringList" },
    "repair_events": { "$ref": "#/$defs/stringList" },
    "rereview_events": { "$ref": "#/$defs/stringList" },
    "validation_results": { "$ref": "#/$defs/stringList" },
    "risk_surfaces": { "$ref": "#/$defs/stringList" },
    "changed_path_risk_surfaces": {
      "description": "Risk surfaces matched from changed file paths only.",
      "$ref": "#/$defs/stringList"
    },
    "command_risk_surfaces": {
      "description": "Risk surfaces matched from a command string only. The full command is never stored.",
      "$ref": "#/$defs/stringList"
    },
    "command_risks": { "$ref": "#/$defs/stringList" },
    "closure_risk_surfaces": {
      "description": "Risk surfaces counted as closure-relevant engineering work. Read-only command matches are intentionally excluded.",
      "$ref": "#/$defs/stringList"
    },
    "professional_injections": { "$ref": "#/$defs/stringList" },
    "permission_decisions": { "$ref": "#/$defs/stringList" },
    "rollback_points": { "$ref": "#/$defs/stringList" },
    "reference_loads": { "$ref": "#/$defs/stringList" },
    "subagent_contracts": { "$ref": "#/$defs/stringList" },
    "compaction_snapshots": { "$ref": "#/$defs/stringList" },
    "prompt_signals": {
      "description": "Compact signal names only; never raw prompt text.",
      "$ref": "#/$defs/stringList"
    },
    "suggested_skills": { "$ref": "#/$defs/stringList" },
    "suggested_capabilities": { "$ref": "#/$defs/stringList" },
    "suggested_domain_extensions": { "$ref": "#/$defs/stringList" },
    "suggested_gates": { "$ref": "#/$defs/stringList" },
    "implementation_preflights": {
      "description": "Bounded summaries of implementation preflight manifests seen this turn; never raw assistant messages.",
      "$ref": "#/$defs/stringList"
    },
    "pre_edit_structure_findings": { "$ref": "#/$defs/stringList" },
    "active_skill_context": {
      "type": "object",
      "additionalProperties": true,
      "description": "Bounded active skill context: stage, owner/reviewer, selected capabilities, gates, and reference paths."
    },
    "turn_stage": {
      "type": "string",
      "enum": [
        "",
        "question",
        "read",
        "plan",
        "edit",
        "test",
        "review",
        "repair",
        "refactor",
        "release",
        "skill_authoring",
        "hook_runtime",
        "permission",
        "subagent",
        "compaction",
        "requirement-intake",
        "architecture-design",
        "implementation-planning",
        "coding",
        "debugging-diagnosis",
        "bug-fix",
        "code-review",
        "refactoring",
        "release-delivery",
        "documentation-handoff",
        "skill-authoring",
        "unknown",
        "no_engineering_action"
      ]
    },
    "owner_skill": { "type": "string", "maxLength": 300 },
    "reviewer_skill": { "type": "string", "maxLength": 300 },
    "stage_route_present": { "type": "boolean" },
    "read_intent_seen": { "type": "boolean" },
    "read_evidence_seen": { "type": "boolean" },
    "reviewed_diff_evidence_seen": { "type": "boolean" },
    "review_intent_seen": { "type": "boolean" },
    "review_artifact_seen": { "type": "boolean" },
    "review_evidence_seen": { "type": "boolean" },
    "repair_evidence_seen": { "type": "boolean" },
    "permission_gate_seen": { "type": "boolean" },
    "professional_contract_seen": { "type": "boolean" },
    "repository_context_seen": {
      "description": "Presence-only signal that repository context evidence was seen this turn.",
      "type": "boolean"
    },
    "workflow_state_seen": {
      "description": "Presence-only signal that workflow state evidence was seen this turn.",
      "type": "boolean"
    },
    "tool_permission_sandbox_seen": {
      "description": "Presence-only signal that tool permission/sandbox evidence was seen this turn.",
      "type": "boolean"
    },
    "skill_efficacy_benchmark_seen": {
      "description": "Presence-only signal that skill-efficacy benchmark evidence was seen this turn.",
      "type": "boolean"
    },
    "plan_execution_consistency_seen": {
      "description": "Presence-only signal that plan-execution consistency evidence was seen this turn.",
      "type": "boolean"
    },
    "validation_freshness_seen": {
      "description": "Presence-only signal that validation freshness evidence was seen this turn.",
      "type": "boolean"
    },
    "implementation_preflight_seen": { "type": "boolean" },
    "implementation_preflight_complete": {
      "description": "Whether a required implementation preflight manifest was present and satisfied the fields required for the observed edit. implementation_preflight_seen only means the manifest was present.",
      "type": "boolean"
    },
    "implementation_preflight_required": { "type": "boolean" },
    "implementation_preflight_blocked": { "type": "boolean" },
    "pre_edit_missing_read_evidence": { "type": "boolean" },
    "pre_edit_missing_reuse_decision": { "type": "boolean" },
    "pre_edit_missing_placement_decision": { "type": "boolean" },
    "pre_edit_missing_test_plan": { "type": "boolean" },
    "edit_without_preflight_seen": { "type": "boolean" },
    "post_edit_confirmed_preflight_gap": { "type": "boolean" },
    "validation_seen": {
      "description": "Backward-compatible alias for validation_command_seen.",
      "type": "boolean"
    },
    "validation_command_seen": {
      "description": "Whether a validation-looking command was observed this turn. This is not completion evidence without an outcome in the stop closure.",
      "type": "boolean"
    },
    "route_preflight_emitted": {
      "description": "Whether the route-preflight reminder was already emitted this turn.",
      "type": "boolean"
    },
    "event_index": {
      "description": "Cache-only monotonic event counter for this turn. It stores order, not prompts or output.",
      "type": "integer",
      "minimum": 0
    },
    "last_material_edit_index": {
      "description": "Latest event index that changed source, tests, docs, config, registry, schemas, templates, build, or install behavior.",
      "type": "integer",
      "minimum": 0
    },
    "last_validation_command_index": {
      "description": "Latest event index where a validation-looking command was observed. Outcome is still required in Stop closure.",
      "type": "integer",
      "minimum": 0
    },
    "turn_id": { "type": "string" },
    "updated_at": { "type": "string" }
  }
}
