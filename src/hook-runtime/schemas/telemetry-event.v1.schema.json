{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://changeforge.dev/schemas/telemetry-event.v1.schema.json",
  "title": "ChangeForge Hook Telemetry Event",
  "description": "One JSONL record appended by a ChangeForge hook to the user cache. Telemetry is a runtime fact log for offline review. It must never contain prompts, environment variables, secrets, full command arguments, or command output.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "timestamp_utc",
    "repo_hash",
    "cwd_hash",
    "runtime",
    "hook_name",
    "event_name",
    "session_id",
    "mode",
    "tool_name",
    "changed_paths",
    "hook_findings",
    "suggested_skills",
    "suggested_capabilities",
    "route_manifest_detected",
    "required_references_detected",
    "validation_evidence_detected",
    "residual_risk_detected"
  ],
  "$defs": {
    "stringList": {
      "type": "array",
      "maxItems": 50,
      "items": { "type": "string", "maxLength": 300 }
    }
  },
  "properties": {
    "schema_version": { "type": "string", "const": "1" },
    "timestamp_utc": {
      "type": "string",
      "description": "UTC ISO 8601 timestamp."
    },
    "repo_hash": {
      "type": "string",
      "description": "SHA-256 prefix of the resolved repository root. Never the absolute path."
    },
    "cwd_hash": {
      "type": "string",
      "description": "SHA-256 prefix of the resolved working directory. Never the absolute path."
    },
    "runtime": {
      "type": "string",
      "enum": ["codex", "claude", "copilot", "generic", "unknown"]
    },
    "hook_name": {
      "type": "string",
      "enum": [
        "session_bootstrap",
        "user_prompt_route_reminder",
        "pre_tool_risk_preview",
        "pre_edit_structure_gate",
        "professional_injector",
        "read_context_gate",
        "review_gate",
        "permission_policy_gate",
        "compaction_snapshot",
        "compaction_reinject",
        "subagent_skill_contract",
        "post_edit_structure_gate",
        "risk_surface_gate",
        "subagent_stop_reminder",
        "stop_closure_gate"
      ]
    },
    "event_name": {
      "type": "string",
      "description": "Hook event such as PostToolUse or Stop."
    },
    "session_id": {
      "type": "string",
      "description": "Session or turn identifier, or a repo+date fallback. Never a prompt."
    },
    "mode": { "type": "string", "enum": ["off", "monitor", "warn", "block"] },
    "tool_name": { "type": "string" },
    "changed_paths": { "$ref": "#/$defs/stringList" },
    "added_paths": { "$ref": "#/$defs/stringList" },
    "command_program": {
      "type": "string",
      "description": "Only the leading executable name of an observed command, truncated. Never full arguments."
    },
    "hook_findings": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/stringList" }
    },
    "suggested_skills": { "$ref": "#/$defs/stringList" },
    "suggested_capabilities": { "$ref": "#/$defs/stringList" },
    "suggested_gates": { "$ref": "#/$defs/stringList" },
    "suggested_domain_extensions": { "$ref": "#/$defs/stringList" },
    "risk_surfaces": { "$ref": "#/$defs/stringList" },
    "route_manifest_detected": { "type": "boolean" },
    "required_references_detected": { "type": "boolean" },
    "validation_evidence_detected": { "type": "boolean" },
    "residual_risk_detected": { "type": "boolean" },
    "completion_language_detected": {
      "type": "boolean",
      "description": "Whether the final handoff text used success-implying completion language. Presence detection only."
    },
    "stage_manifest_detected": { "type": "boolean" },
    "manifest_current_stage": { "type": "string", "maxLength": 300 },
    "manifest_selected_skills": { "$ref": "#/$defs/stringList" },
    "manifest_selected_capabilities": { "$ref": "#/$defs/stringList" },
    "manifest_selected_domain_extensions": { "$ref": "#/$defs/stringList" },
    "manifest_required_references": { "$ref": "#/$defs/stringList" },
    "manifest_required_quality_gates": { "$ref": "#/$defs/stringList" },
    "manifest_skipped_quality_gates": { "$ref": "#/$defs/stringList" },
    "turn_stage": { "type": "string", "maxLength": 300 },
    "owner_skill": { "type": "string", "maxLength": 300 },
    "reviewer_skill": { "type": "string", "maxLength": 300 },
    "read_evidence_seen": { "type": "boolean" },
    "review_evidence_seen": { "type": "boolean" },
    "repair_evidence_seen": { "type": "boolean" },
    "permission_gate_seen": { "type": "boolean" },
    "professional_contract_seen": { "type": "boolean" },
    "implementation_preflight_required": { "type": "boolean" },
    "implementation_preflight_seen": { "type": "boolean" },
    "implementation_preflight_complete": {
      "description": "Whether a required implementation preflight manifest was present and satisfied the fields required for the observed edit. implementation_preflight_seen only means the manifest was present.",
      "type": "boolean"
    },
    "implementation_preflight_blocked": { "type": "boolean" },
    "edit_without_preflight_seen": { "type": "boolean" },
    "post_edit_confirmed_preflight_gap": { "type": "boolean" }
  }
}
