{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://changeforge.dev/schemas/telemetry-event.v1.schema.json",
  "title": "ChangeForge Hook Telemetry Event",
  "description": "One JSONL record appended by a ChangeForge hook to the user cache. Telemetry is a runtime fact log for offline review. It must never contain prompts, environment variables, secrets, full command arguments, or command output.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "timestamp_utc",
    "repo_hash",
    "cwd_hash",
    "runtime",
    "hook_name",
    "event_name",
    "session_id",
    "mode",
    "tool_name",
    "changed_paths",
    "hook_findings",
    "suggested_skills",
    "suggested_capabilities",
    "route_manifest_detected",
    "required_references_detected",
    "validation_evidence_detected",
    "residual_risk_detected"
  ],
  "$defs": {
    "stringList": {
      "type": "array",
      "maxItems": 50,
      "items": { "type": "string", "maxLength": 300 }
    },
    "validationBrokerCommandLedger": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "command_kind": {
            "type": "string",
            "enum": ["", "narrow", "module", "full", "unknown"]
          },
          "command_display_safe": { "type": "string", "maxLength": 300 },
          "scope": {
            "type": "string",
            "enum": ["", "narrow", "module", "full", "none", "unknown"]
          },
          "outcome": {
            "type": "string",
            "enum": [
              "",
              "passed",
              "failed",
              "not_run",
              "not_verified",
              "stale",
              "partial",
              "unknown"
            ]
          },
          "finished_at_or_order": { "type": "string", "maxLength": 300 },
          "covered_paths": { "$ref": "#/$defs/stringList" },
          "covered_risk_surfaces": { "$ref": "#/$defs/stringList" },
          "evidence_strength": {
            "type": "string",
            "enum": ["", "none", "weak", "partial", "strong", "negative"]
          }
        }
      }
    },
    "changeforgeClosure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "type": "string",
          "enum": [
            "",
            "codex",
            "claude",
            "copilot",
            "generic",
            "unknown",
            "cline",
            "roo",
            "openhands",
            "gemini-cli",
            "goose"
          ]
        },
        "verdict": {
          "type": "string",
          "enum": [
            "",
            "ready",
            "needs_validation",
            "needs_review",
            "needs_repair",
            "degraded_ready",
            "blocked"
          ]
        },
        "supported_checks": { "$ref": "#/$defs/stringList" },
        "unsupported_checks": { "$ref": "#/$defs/stringList" },
        "degraded_capabilities": { "$ref": "#/$defs/stringList" },
        "present_evidence": { "$ref": "#/$defs/stringList" },
        "missing_evidence": { "$ref": "#/$defs/stringList" },
        "negative_evidence": { "$ref": "#/$defs/stringList" },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "outcome": {
              "type": "string",
              "enum": [
                "",
                "pass",
                "fail",
                "failed",
                "stale",
                "not_run",
                "not_verified",
                "no_outcome",
                "unknown"
              ]
            },
            "freshness": {
              "type": "string",
              "enum": ["", "current", "stale", "unknown", "not_applicable"]
            },
            "scope": {
              "type": "string",
              "enum": ["", "narrow", "module", "full", "none", "unknown"]
            },
            "command_kind": {
              "type": "string",
              "enum": ["", "narrow", "module", "full", "unknown"]
            }
          }
        },
        "review": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "review_outcome": { "type": "string", "maxLength": 300 },
            "repair_present": { "type": "boolean" },
            "rereview_present": { "type": "boolean" }
          }
        },
        "changed_files": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "changed": { "$ref": "#/$defs/stringList" },
            "deleted": { "$ref": "#/$defs/stringList" },
            "generated": { "$ref": "#/$defs/stringList" }
          }
        },
        "residual_risk": { "$ref": "#/$defs/stringList" },
        "next_owner": { "type": "string", "maxLength": 300 }
      }
    }
  },
  "properties": {
    "schema_version": { "type": "string", "const": "1" },
    "timestamp_utc": {
      "type": "string",
      "description": "UTC ISO 8601 timestamp."
    },
    "repo_hash": {
      "type": "string",
      "description": "SHA-256 prefix of the resolved repository root. Never the absolute path."
    },
    "cwd_hash": {
      "type": "string",
      "description": "SHA-256 prefix of the resolved working directory. Never the absolute path."
    },
    "runtime": {
      "type": "string",
      "enum": ["codex", "claude", "copilot", "generic", "unknown", "cline", "roo", "openhands", "gemini-cli", "goose"]
    },
    "hook_name": {
      "type": "string",
      "enum": [
        "session_bootstrap",
        "user_prompt_route_reminder",
        "pre_tool_risk_preview",
        "pre_edit_structure_gate",
        "professional_injector",
        "read_context_gate",
        "review_gate",
        "permission_policy_gate",
        "compaction_snapshot",
        "compaction_reinject",
        "subagent_skill_contract",
        "post_edit_structure_gate",
        "risk_surface_gate",
        "subagent_stop_reminder",
        "stop_closure_gate"
      ]
    },
    "event_name": {
      "type": "string",
      "description": "Hook event such as PostToolUse or Stop."
    },
    "session_id": {
      "type": "string",
      "description": "Session or turn identifier, or a repo+date fallback. Never a prompt."
    },
    "mode": { "type": "string", "enum": ["off", "monitor", "warn", "block"] },
    "tool_name": { "type": "string" },
    "normalized_events": { "$ref": "#/$defs/stringList" },
    "changed_paths": { "$ref": "#/$defs/stringList" },
    "deleted_paths": { "$ref": "#/$defs/stringList" },
    "generated_paths": { "$ref": "#/$defs/stringList" },
    "external_file_changes": { "$ref": "#/$defs/stringList" },
    "config_changes": { "$ref": "#/$defs/stringList" },
    "added_paths": { "$ref": "#/$defs/stringList" },
    "command_program": {
      "type": "string",
      "description": "Only the leading executable name of an observed command, truncated. Never full arguments."
    },
    "command_risk": {
      "type": "string",
      "enum": [
        "",
        "safe",
        "mutation",
        "destructive",
        "release",
        "migration",
        "dependency",
        "network",
        "unknown"
      ]
    },
    "permission_decision": {
      "type": "string",
      "enum": ["", "allow", "warn", "block", "deny", "unknown"]
    },
    "hook_findings": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/stringList" }
    },
    "post_edit_structure_findings": { "$ref": "#/$defs/stringList" },
    "suggested_skills": { "$ref": "#/$defs/stringList" },
    "suggested_capabilities": { "$ref": "#/$defs/stringList" },
    "suggested_gates": { "$ref": "#/$defs/stringList" },
    "suggested_domain_extensions": { "$ref": "#/$defs/stringList" },
    "risk_surfaces": { "$ref": "#/$defs/stringList" },
    "changed_path_risk_surfaces": {
      "description": "Risk surfaces matched from changed file paths only.",
      "$ref": "#/$defs/stringList"
    },
    "command_risk_surfaces": {
      "description": "Risk surfaces matched from a command string only. The full command is never recorded.",
      "$ref": "#/$defs/stringList"
    },
    "closure_risk_surfaces": {
      "description": "Risk surfaces counted as closure-relevant engineering work. Read-only command matches are intentionally excluded.",
      "$ref": "#/$defs/stringList"
    },
    "route_manifest_detected": { "type": "boolean" },
    "required_references_detected": { "type": "boolean" },
    "validation_command_detected": {
      "type": "boolean",
      "description": "Whether a validation-looking command was observed earlier in the turn. This is not validation evidence without an outcome in the stop closure."
    },
    "validation_results": { "$ref": "#/$defs/stringList" },
    "validation_evidence_detected": { "type": "boolean" },
    "validation_result_outcome": {
      "type": "string",
      "enum": ["", "pass", "fail", "stale", "unknown", "not_run"],
      "description": "Broker-parsed outcome from bounded closure evidence."
    },
    "validation_result_evidence_strength": {
      "type": "string",
      "enum": ["", "strong", "partial", "weak", "negative"]
    },
    "validation_result_negative_reason": {
      "type": "string",
      "enum": ["", "not_run", "unable_to_run", "stale", "failed", "no_outcome"]
    },
    "validation_result_command_kind": {
      "type": "string",
      "enum": ["", "narrow", "module", "full", "unknown"]
    },
    "validation_result_fresh_after_last_edit": {
      "type": "string",
      "enum": ["", "true", "false", "unknown"]
    },
    "validation_result_coverage_aligned": {
      "type": "string",
      "enum": ["", "true", "false", "unknown"]
    },
    "validation_result_covered_paths": { "$ref": "#/$defs/stringList" },
    "validation_result_covered_risk_surfaces": { "$ref": "#/$defs/stringList" },
    "validation_broker_closure_outcome": {
      "type": "string",
      "enum": ["", "ready", "needs_validation", "degraded_ready", "blocked"]
    },
    "validation_broker_selected_scope": {
      "type": "string",
      "enum": ["", "narrow", "module", "full", "none"]
    },
    "validation_broker_negative_evidence": { "$ref": "#/$defs/stringList" },
    "validation_broker_residual_risk": { "$ref": "#/$defs/stringList" },
    "validation_broker_command_ledger": {
      "$ref": "#/$defs/validationBrokerCommandLedger"
    },
    "adapter_name": {
      "type": "string",
      "enum": [
        "",
        "codex",
        "claude",
        "copilot",
        "generic",
        "unknown",
        "cline",
        "roo",
        "openhands",
        "gemini-cli",
        "goose"
      ]
    },
    "adapter_supported_checks": { "$ref": "#/$defs/stringList" },
    "adapter_unsupported_checks": { "$ref": "#/$defs/stringList" },
    "adapter_degraded_capabilities": { "$ref": "#/$defs/stringList" },
    "closure_contract_verdict": {
      "type": "string",
      "enum": [
        "",
        "ready",
        "needs_validation",
        "needs_review",
        "needs_repair",
        "degraded_ready",
        "blocked"
      ]
    },
    "closure_contract_residual_risk": { "$ref": "#/$defs/stringList" },
    "changeforge_closure": { "$ref": "#/$defs/changeforgeClosure" },
    "project_memory_available": {
      "description": "Whether the cache-side project memory advisory store was readable for this Stop evaluation.",
      "type": "boolean"
    },
    "project_memory_projection_key": {
      "description": "Deterministic key for the bounded memory facts considered at Stop.",
      "type": "string",
      "maxLength": 300
    },
    "project_memory_included_events": { "$ref": "#/$defs/stringList" },
    "project_memory_excluded_events": { "$ref": "#/$defs/stringList" },
    "project_memory_stale_context_gate": {
      "type": "string",
      "enum": ["", "pass", "warn", "block"]
    },
    "project_memory_residual_risk": { "$ref": "#/$defs/stringList" },
    "residual_risk_detected": { "type": "boolean" },
    "completion_language_detected": {
      "type": "boolean",
      "description": "Whether the final handoff text used success-implying completion language. Presence detection only."
    },
    "stage_manifest_detected": { "type": "boolean" },
    "manifest_current_stage": { "type": "string", "maxLength": 300 },
    "manifest_selected_skills": { "$ref": "#/$defs/stringList" },
    "manifest_selected_capabilities": { "$ref": "#/$defs/stringList" },
    "manifest_selected_domain_extensions": { "$ref": "#/$defs/stringList" },
    "manifest_required_references": { "$ref": "#/$defs/stringList" },
    "manifest_required_quality_gates": { "$ref": "#/$defs/stringList" },
    "manifest_skipped_quality_gates": { "$ref": "#/$defs/stringList" },
    "turn_stage": { "type": "string", "maxLength": 300 },
    "owner_skill": { "type": "string", "maxLength": 300 },
    "reviewer_skill": { "type": "string", "maxLength": 300 },
    "read_evidence_seen": { "type": "boolean" },
    "review_evidence_seen": { "type": "boolean" },
    "repair_evidence_seen": { "type": "boolean" },
    "permission_gate_seen": { "type": "boolean" },
    "professional_contract_seen": { "type": "boolean" },
    "repository_context_seen": {
      "description": "Presence-only signal that repository context evidence was detected in closure.",
      "type": "boolean"
    },
    "workflow_state_seen": {
      "description": "Presence-only signal that workflow state evidence was detected in closure.",
      "type": "boolean"
    },
    "tool_permission_sandbox_seen": {
      "description": "Presence-only signal that tool permission/sandbox evidence was detected in closure.",
      "type": "boolean"
    },
    "skill_efficacy_benchmark_seen": {
      "description": "Presence-only signal that skill-efficacy benchmark evidence was detected in closure.",
      "type": "boolean"
    },
    "plan_execution_consistency_seen": {
      "description": "Presence-only signal that plan-execution consistency evidence was detected in closure.",
      "type": "boolean"
    },
    "validation_freshness_seen": {
      "description": "Presence-only signal that validation freshness evidence was detected in closure.",
      "type": "boolean"
    },
    "implementation_preflight_required": { "type": "boolean" },
    "implementation_preflight_seen": { "type": "boolean" },
    "implementation_preflight_complete": {
      "description": "Whether a required implementation preflight manifest was present and satisfied the fields required for the observed edit. implementation_preflight_seen only means the manifest was present.",
      "type": "boolean"
    },
    "implementation_preflight_blocked": { "type": "boolean" },
    "edit_without_preflight_seen": { "type": "boolean" },
    "post_edit_confirmed_preflight_gap": { "type": "boolean" }
  }
}
