+def _canonical_host(host: str | None) -> str:
+    if not host:
+        raise URLPolicyError("parse_failed")
+    try:
+        return host.rstrip(".").encode("idna").decode("ascii").casefold()
+    except UnicodeError as exc:
+        raise URLPolicyError("parse_failed") from exc
+
+
+def _address_is_denied(address: str) -> bool:
+    try:
+        parsed = ipaddress.ip_address(address)
+    except ValueError as exc:
+        raise URLPolicyError("dns_failed") from exc
+
+    # is_global excludes private, loopback, link-local, multicast, reserved,
+    # unspecified, and common special-use ranges including 169.254.169.254.
+    return not parsed.is_global
+
+
+def _validated_url(
+    url: str,
+    resolver: Callable[..., Iterable[str]],
+) -> ValidatedURL:
+    try:
+        parsed = urlparse(url)
+        host = _canonical_host(parsed.hostname)
+        port = parsed.port or 443
+    except ValueError as exc:
+        raise URLPolicyError("parse_failed") from exc
+
+    if parsed.scheme.casefold() != "https":
+        raise URLPolicyError("scheme_not_allowed")
+    if parsed.username or parsed.password:
+        raise URLPolicyError("parse_failed")
+    if (host, port) not in ALLOWED_HTTPS_ORIGINS:
+        raise URLPolicyError("host_not_allowed")
+
+    try:
+        addresses = tuple(resolver(host))
+    except Exception as exc:
+        raise URLPolicyError("dns_failed") from exc
+    if not addresses:
+        raise URLPolicyError("dns_failed")
+    if any(_address_is_denied(address) for address in addresses):
+        raise URLPolicyError("network_not_allowed")
+
+    netloc = host if port == 443 else f"{host}:{port}"
+    canonical = urlunparse(
+        (
+            "https",
+            netloc,
+            parsed.path or "/",
+            parsed.params,
+            parsed.query,
+            "",
+        )
+    )
+    return ValidatedURL(url=canonical, host=host, port=port, addresses=addresses)
 
 
