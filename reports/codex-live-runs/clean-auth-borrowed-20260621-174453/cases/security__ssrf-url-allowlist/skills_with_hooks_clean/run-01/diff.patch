+def _canonical_host(host: str | None) -> str | None:
+    if not host:
+        return None
+    try:
+        return host.rstrip(".").encode("idna").decode("ascii").casefold()
+    except UnicodeError:
+        return None
+
+
+def _is_public_address(address: str) -> bool:
+    try:
+        ip = ipaddress.ip_address(address)
+    except ValueError:
+        return False
+    return not (
+        ip.is_loopback
+        or ip.is_link_local
+        or ip.is_private
+        or ip.is_multicast
+        or ip.is_reserved
+        or ip.is_unspecified
+    )
+
+
+def _validate_fetch_url(
+    raw_url: str,
+    resolver: Callable[..., Iterable[str]],
+) -> tuple[bool, str, str | None]:
+    try:
+        parsed = urlparse(raw_url)
+        host = _canonical_host(parsed.hostname)
+    except Exception:
+        return False, "invalid_url", None
+    if parsed.scheme.casefold() != "https" or host not in ALLOWED_HTTPS_HOSTS:
+        return False, "host_not_allowed", None
+    if parsed.username or parsed.password:
+        return False, "userinfo_not_allowed", None
+    try:
+        port = parsed.port
+    except ValueError:
+        return False, "invalid_url", None
+    if port not in (None, HTTPS_PORT):
+        return False, "port_not_allowed", None
+
+    try:
+        addresses = tuple(resolver(host))
+    except Exception:
+        return False, "dns_resolution_failed", None
+    if not addresses:
+        return False, "dns_resolution_failed", None
+    if any(not _is_public_address(address) for address in addresses):
+        return False, "private_network_denied", None
+
+    normalized = parsed._replace(scheme="https", netloc=host).geturl()
+    return True, "allowed", normalized
 
 
