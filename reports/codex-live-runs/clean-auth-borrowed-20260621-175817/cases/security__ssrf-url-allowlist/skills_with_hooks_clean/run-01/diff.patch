+def _canonical_host(host: str | None) -> str | None:
+    if not host:
+        return None
+    try:
+        return host.rstrip(".").casefold().encode("idna").decode("ascii")
+    except UnicodeError:
+        return None
+
+
+def _address_is_denied(address: str) -> bool:
+    try:
+        parsed = ipaddress.ip_address(address)
+    except ValueError:
+        return True
+    return (
+        parsed.is_private
+        or parsed.is_loopback
+        or parsed.is_link_local
+        or parsed.is_multicast
+        or parsed.is_reserved
+        or parsed.is_unspecified
+    )
+
+
+def _validate_fetch_url(
+    url: str,
+    *,
+    resolver: Callable[..., Iterable[str]],
+    policy: NetworkPolicy,
+) -> tuple[str | None, str | None]:
+    try:
+        parsed = urlparse(url)
+        port = parsed.port or 443
+    except (TypeError, ValueError):
+        return None, "invalid_url"
+
+    host = _canonical_host(parsed.hostname)
+    if parsed.scheme.casefold() != "https" or not host:
+        return None, "host_not_allowed"
+    if parsed.username or parsed.password:
+        return None, "invalid_url"
+    if host not in policy.allowed_hosts or port not in policy.allowed_ports:
+        return None, "host_not_allowed"
+
+    try:
+        addresses = list(resolver(host))
+    except Exception:
+        return None, "dns_failure"
+    if not addresses:
+        return None, "dns_failure"
+    if any(_address_is_denied(address) for address in addresses):
+        return None, "unsafe_network"
+
+    canonical_netloc = host if port == 443 else f"{host}:{port}"
+    return parsed._replace(scheme="https", netloc=canonical_netloc).geturl(), None
 
 
