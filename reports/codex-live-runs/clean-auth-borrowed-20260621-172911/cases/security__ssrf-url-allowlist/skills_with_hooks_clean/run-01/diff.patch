-def _host_is_allowed(host: str | None) -> bool:
-    # Known benchmark gap: prefix matching accepts attacker-controlled hosts.
-    return bool(host and host.startswith("preview.example.com"))
+def _host_is_allowed(host: str) -> bool:
+    return host in ALLOWED_HTTPS_HOSTS
+
+
+def _canonical_host(host: str | None) -> str | None:
+    if not host:
+        return None
+    try:
+        return host.rstrip(".").encode("idna").decode("ascii").casefold()
+    except UnicodeError:
+        return None
+
+
+def _canonical_url(parsed: ParseResult, host: str, port: int) -> str:
+    netloc = host if port == HTTPS_PORT else f"{host}:{port}"
+    return urlunparse(
+        (
+            "https",
+            netloc,
+            parsed.path or "/",
+            "",
+            parsed.query,
+            "",
+        )
+    )
+
+
+def _is_blocked_address(address: str) -> bool:
+    ip = ipaddress.ip_address(address)
+    metadata_addresses = {
+        ipaddress.ip_address("169.254.169.254"),
+        ipaddress.ip_address("fd00:ec2::254"),
+    }
+    return ip in metadata_addresses or not ip.is_global
+
+
+def _validate_url(
+    url: str,
+    *,
+    resolver: Callable[..., Iterable[str]],
+) -> tuple[str | None, str | None]:
+    try:
+        parsed = urlparse(url)
+        host = _canonical_host(parsed.hostname)
+        port = parsed.port or HTTPS_PORT
+    except (TypeError, ValueError):
+        return None, "invalid_url"
+
+    if parsed.scheme.casefold() != "https" or host is None:
+        return None, "host_not_allowed"
+    if parsed.username or parsed.password:
+        return None, "invalid_url"
+    if port != HTTPS_PORT or not _host_is_allowed(host):
+        return None, "host_not_allowed"
+
+    try:
+        resolved_addresses = tuple(resolver(host))
+    except Exception:
+        return None, "dns_failed"
+
+    if not resolved_addresses:
+        return None, "dns_failed"
+
+    try:
+        if any(_is_blocked_address(address) for address in resolved_addresses):
+            return None, "network_not_allowed"
+    except ValueError:
+        return None, "dns_failed"
+
+    return _canonical_url(parsed, host, port), None
 
 
