+def _canonical_host(host: str | None) -> str | None:
+    if host is None:
+        return None
+    host = host.rstrip(".").casefold()
+    if not host:
+        return None
+    try:
+        return host.encode("idna").decode("ascii")
+    except UnicodeError:
+        return None
+
+
+def _safe_ip_address(address: str) -> bool:
+    try:
+        parsed = ipaddress.ip_address(address)
+    except ValueError:
+        return False
+    return parsed.is_global and parsed not in METADATA_SERVICE_ADDRESSES
+
+
+def _normalized_url(url: str, host: str, port: int) -> str:
+    parsed = urlparse(url)
+    netloc = host if port == DEFAULT_HTTPS_PORT else f"{host}:{port}"
+    return urlunparse(
+        (
+            "https",
+            netloc,
+            parsed.path or "/",
+            parsed.params,
+            parsed.query,
+            "",
+        )
+    )
+
+
+def _validate_fetch_url(
+    url: str,
+    *,
+    resolver: Callable[..., Iterable[str]],
+    allowed_hosts: frozenset[str] = ALLOWED_PREVIEW_HOSTS,
+) -> tuple[str | None, str]:
+    try:
+        parsed = urlparse(url)
+        port = parsed.port or DEFAULT_HTTPS_PORT
+    except ValueError:
+        return None, "parse_error"
+
+    host = _canonical_host(parsed.hostname)
+    if parsed.scheme.casefold() != "https" or host not in allowed_hosts:
+        return None, "host_not_allowed"
+    if port != DEFAULT_HTTPS_PORT:
+        return None, "port_not_allowed"
+
+    try:
+        addresses = tuple(resolver(host))
+    except Exception:
+        return None, "dns_resolution_failed"
+    if not addresses:
+        return None, "dns_resolution_failed"
+    if not all(_safe_ip_address(address) for address in addresses):
+        return None, "network_not_allowed"
+
+    return _normalized_url(url, host, port), ""
 
 
