+def _canonical_host(host: str | None) -> str | None:
+    if not host:
+        return None
+    try:
+        canonical = host.rstrip(".").encode("idna").decode("ascii").casefold()
+    except UnicodeError:
+        return None
+    return canonical or None
+
+
+def _canonical_url(parsed: ParseResult, host: str, port: int) -> str:
+    netloc = host if port == DEFAULT_HTTPS_PORT else f"{host}:{port}"
+    return urlunparse(
+        (
+            "https",
+            netloc,
+            parsed.path or "",
+            parsed.params,
+            parsed.query,
+            "",
+        )
+    )
+
+
+def _address_is_denied(address: ipaddress.IPv4Address | ipaddress.IPv6Address) -> bool:
+    if isinstance(address, ipaddress.IPv6Address) and address.ipv4_mapped is not None:
+        return _address_is_denied(address.ipv4_mapped)
+    return (
+        address in METADATA_ADDRESSES
+        or address.is_loopback
+        or address.is_link_local
+        or address.is_private
+        or address.is_unspecified
+        or address.is_multicast
+    )
+
+
+def _resolve_safe_addresses(
+    host: str,
+    resolver: Callable[..., Iterable[str]],
+) -> tuple[bool, str, tuple[str, ...]]:
+    try:
+        raw_addresses = tuple(resolver(host))
+    except AssertionError:
+        raise
+    except Exception:
+        return False, "dns_resolution_failed", ()
+
+    if not raw_addresses:
+        return False, "dns_resolution_failed", ()
+
+    addresses: list[str] = []
+    for raw_address in raw_addresses:
+        try:
+            address = ipaddress.ip_address(str(raw_address).strip())
+        except ValueError:
+            return False, "dns_resolution_failed", ()
+        if _address_is_denied(address):
+            return False, "address_not_allowed", ()
+        addresses.append(str(address))
+    return True, "", tuple(addresses)
+
+
+def _validate_fetch_url(
+    url: str,
+    resolver: Callable[..., Iterable[str]],
+) -> tuple[_ValidatedURL | None, str]:
+    try:
+        parsed = urlparse(url)
+        port = parsed.port or DEFAULT_HTTPS_PORT
+    except ValueError:
+        return None, "invalid_url"
+
+    host = _canonical_host(parsed.hostname)
+    if (
+        parsed.scheme.casefold() != "https"
+        or host not in ALLOWED_HTTPS_HOSTS
+        or port != DEFAULT_HTTPS_PORT
+        or parsed.username is not None
+        or parsed.password is not None
+    ):
+        return None, "host_not_allowed"
+
+    ok, reason, addresses = _resolve_safe_addresses(host, resolver)
+    if not ok:
+        return None, reason
+
+    return _ValidatedURL(
+        url=_canonical_url(parsed, host, port),
+        host=host,
+        port=port,
+        addresses=addresses,
+    ), ""
 
 
