index 7cf5f9b..69335f6 100644
--- a/setup.sh
+++ b/setup.sh
@@ -1,3 +1,22 @@
 #!/usr/bin/env bash
 set -euo pipefail
-python3 ../../../../../scripts/codegen_benchmark_harness.py setup "$PWD"
\ No newline at end of file
+
+script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+search_dir="$script_dir"
+harness=""
+
+while [[ "$search_dir" != "/" ]]; do
+  candidate="$search_dir/scripts/codegen_benchmark_harness.py"
+  if [[ -f "$candidate" ]]; then
+    harness="$candidate"
+    break
+  fi
+  search_dir="$(dirname "$search_dir")"
+done
+
+if [[ -z "$harness" ]]; then
+  echo "setup: unable to find scripts/codegen_benchmark_harness.py" >&2
+  exit 1
+fi
+
+python3 "$harness" setup "$PWD"
