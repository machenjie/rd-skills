+def _canonical_host(host: str | None) -> str | None:
+    if host is None:
+        return None
+
+    candidate = host.rstrip(".").casefold()
+    if not candidate:
+        return None
+
+    try:
+        ascii_host = candidate.encode("idna").decode("ascii")
+    except UnicodeError:
+        return None
+
+    labels = ascii_host.split(".")
+    if (
+        any(not label or len(label) > 63 for label in labels)
+        or len(ascii_host) > 253
+    ):
+        return None
+    return ascii_host
+
+
+def _resolve_addresses(
+    host: str,
+    resolver: Callable[[str], Iterable[str]],
+) -> tuple[_Address, ...]:
+    try:
+        raw_addresses = tuple(resolver(host))
+    except Exception as exc:
+        raise _NetworkPolicyError("dns_resolution_failed") from exc
+
+    if not raw_addresses:
+        raise _NetworkPolicyError("dns_resolution_failed")
+
+    addresses: list[_Address] = []
+    for raw_address in raw_addresses:
+        try:
+            addresses.append(ipaddress.ip_address(str(raw_address).strip()))
+        except ValueError as exc:
+            raise _NetworkPolicyError("dns_resolution_failed") from exc
+    return tuple(addresses)
+
+
+def _address_forms(address: _Address) -> Iterable[_Address]:
+    yield address
+    if isinstance(address, ipaddress.IPv6Address) and address.ipv4_mapped:
+        yield address.ipv4_mapped
+
+
+def _address_is_denied(address: _Address) -> bool:
+    for address_form in _address_forms(address):
+        if address_form in _METADATA_ADDRESSES:
+            return True
+        if (
+            address_form.is_loopback
+            or address_form.is_link_local
+            or address_form.is_unspecified
+            or address_form.is_multicast
+        ):
+            return True
+        if any(
+            address_form.version == network.version and address_form in network
+            for network in _DENIED_NETWORKS
+        ):
+            return True
+    return False
+
+
+def _validate_fetch_target(
+    url: str,
+    resolver: Callable[[str], Iterable[str]],
+) -> _ValidatedFetchTarget:
+    try:
+        parsed = urlsplit(url)
+        port = parsed.port or 443
+    except ValueError as exc:
+        raise _NetworkPolicyError("invalid_url") from exc
+
+    host = _canonical_host(parsed.hostname)
+    if (
+        parsed.scheme.casefold() != "https"
+        or parsed.username is not None
+        or parsed.password is not None
+        or host not in ALLOWED_HTTPS_HOSTS
+        or port not in ALLOWED_HTTPS_PORTS
+    ):
+        raise _NetworkPolicyError("host_not_allowed")
+
+    addresses = _resolve_addresses(host, resolver)
+    if any(_address_is_denied(address) for address in addresses):
+        raise _NetworkPolicyError("network_not_allowed")
+
+    netloc = host if port == 443 else f"{host}:{port}"
+    canonical_url = urlunsplit(("https", netloc, parsed.path or "/", parsed.query, ""))
+    return _ValidatedFetchTarget(
+        canonical_url=canonical_url,
+        host=host,
+        port=port,
+        addresses=addresses,
+    )
 
 
