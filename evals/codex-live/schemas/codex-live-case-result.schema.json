{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://changeforge.local/schemas/codex-live-case-result.schema.json",
  "title": "Codex live benchmark case result",
  "type": "object",
  "required": [
    "schema_version",
    "generated_by",
    "case_id",
    "variant",
    "run_index",
    "status",
    "artifact_status",
    "grading_status",
    "benchmark_mode",
    "codex_home_mode",
    "auth_policy",
    "codex_environment_policy",
    "grading_mode",
    "publishable_for_strict",
    "benchmark_eligible",
    "benchmark_passed",
    "failure_category",
    "setup_failure_reason",
    "setup_failure_subreason",
    "setup_contract",
    "test_suite_failure_reason",
    "security_failure_reason",
    "first_failure_stage",
    "first_failure_excerpt",
    "setup_log_excerpt",
    "test_suite_log_excerpt",
    "security_log_excerpt",
    "contamination",
    "environment",
    "paths",
    "grading",
    "metrics",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "type": "integer"
    },
    "generated_by": {
      "const": "scripts/run-codex-live-benchmarks.py"
    },
    "case_id": {
      "type": "string"
    },
    "variant": {
      "enum": ["baseline_clean", "skills_only_clean", "skills_with_hooks_clean", "current_home_smoke"]
    },
    "run_index": {
      "type": "integer"
    },
    "status": {
      "enum": ["not_collected", "skipped_not_opted_in", "partial", "collected", "failed"]
    },
    "artifact_status": {
      "enum": ["collected", "partial", "failed"]
    },
    "grading_status": {
      "enum": ["passed", "failed", "not_collected", "telemetry_only", "contaminated"]
    },
    "benchmark_mode": {
      "enum": ["clean-paired", "ablation", "current-home-smoke"]
    },
    "codex_home_mode": {
      "enum": ["isolated", "current"]
    },
    "auth_policy": {
      "enum": ["isolated-api-key", "borrow-current", "current-home-full"]
    },
    "codex_environment_policy": {
      "enum": ["isolated_api_key", "auth_borrowed_clean", "current_home_full"]
    },
    "grading_mode": {
      "enum": ["assertion", "telemetry_only"]
    },
    "publishable_for_strict": {
      "type": "boolean"
    },
    "benchmark_eligible": {
      "type": "boolean"
    },
    "benchmark_passed": {
      "type": "boolean"
    },
    "failure_category": {
      "enum": [
        "none",
        "codex_exec_failed",
        "install_failed",
        "setup_failed",
        "test_suite_failed",
        "security_checks_failed",
        "contaminated",
        "grading_not_collected",
        "telemetry_only"
      ]
    },
    "setup_failure_reason": {
      "enum": [
        "none",
        "missing_harness",
        "setup_script_missing",
        "setup_script_modified_bad_path",
        "dependency_install_failed",
        "python_compile_failed",
        "candidate_removed_required_file",
        "permission_denied",
        "shell_error",
        "unknown"
      ]
    },
    "setup_failure_subreason": {
      "enum": [
        "none",
        "candidate_modified_setup",
        "starter_fragile_path",
        "missing_env_root",
        "wrong_cwd",
        "missing_harness",
        "classifier_uncertain",
        "unknown"
      ]
    },
    "setup_contract": {
      "type": "object",
      "required": [
        "candidate_setup_exists",
        "candidate_setup_hash_changed",
        "candidate_setup_mentions_changeforge_codegen_root",
        "candidate_setup_uses_fixed_parent_traversal",
        "candidate_setup_invokes_codegen_harness"
      ]
    },
    "test_suite_failure_reason": {
      "enum": ["none", "assertion_failed", "missing_test_script", "python_import_failed", "python_compile_failed", "behavior_failed", "unknown"]
    },
    "security_failure_reason": {
      "enum": ["none", "assertion_failed", "missing_security_script", "sensitive_log_leak", "unsafe_network_policy", "unknown"]
    },
    "first_failure_stage": {
      "enum": ["setup", "test_suite", "security_checks", "assertion_files", "none"]
    },
    "first_failure_excerpt": {
      "type": "string",
      "maxLength": 1200
    },
    "setup_log_excerpt": {
      "type": "string",
      "maxLength": 1200
    },
    "test_suite_log_excerpt": {
      "type": "string",
      "maxLength": 1200
    },
    "security_log_excerpt": {
      "type": "string",
      "maxLength": 1200
    },
    "contamination": {
      "type": "object",
      "required": ["contaminated", "signals", "files"]
    },
    "environment": {
      "type": "object",
      "required": [
        "home",
        "codex_home",
        "user_home_visible",
        "user_skills_visible",
        "user_config_loaded",
        "user_rules_loaded",
        "current_auth_borrowed",
        "ignore_user_config",
        "ignore_rules",
        "plugins_disabled"
      ]
    },
    "paths": {
      "type": "object"
    },
    "grading": {
      "type": "object"
    },
    "metrics": {
      "type": "object"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}
