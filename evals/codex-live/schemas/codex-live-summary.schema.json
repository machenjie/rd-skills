{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://changeforge.local/schemas/codex-live-summary.schema.json",
  "title": "Codex live benchmark summary",
  "type": "object",
  "required": [
    "schema_version",
    "generated_by",
    "status",
    "evidence_level",
    "evidence_scope",
    "evidence_scope_detail",
    "evidence_status",
    "effect_verdict",
    "effect_status",
    "effect_summary",
    "benchmark_mode",
    "codex_home_policy",
    "auth_policy",
    "codex_environment_policy",
    "strict_benchmark_eligible",
    "run_id",
    "case_count",
    "assertion_case_count",
    "telemetry_only_case_count",
    "result_count",
    "benchmark_eligible_result_count",
    "benchmark_passed_result_count",
    "not_collected_grading_count",
    "telemetry_only_result_count",
    "contaminated_result_count",
    "failure_categories",
    "setup_failure_reasons",
    "dominant_setup_failure_reason",
    "setup_failure_subreasons",
    "dominant_setup_failure_subreason",
    "unknown_setup_failure_rate",
    "test_suite_failure_reasons",
    "security_failure_reasons",
    "current_home_result_count",
    "current_home_full_result_count",
    "user_skills_visible",
    "user_config_loaded",
    "user_rules_loaded",
    "ignore_user_config",
    "ignore_rules",
    "plugins_disabled",
    "variants",
    "delta",
    "cases",
    "cases_summary",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "type": "integer"
    },
    "generated_by": {
      "const": "scripts/generate-codex-live-summary.py"
    },
    "status": {
      "enum": ["not_collected", "skipped_not_opted_in", "partial", "collected", "failed"]
    },
    "evidence_level": {
      "enum": ["local_codex_cli_live_benchmark", "current_home_integration_smoke"]
    },
    "evidence_scope": {
      "enum": ["smoke", "multi_case_ablation_3_run", "current_home_smoke"]
    },
    "evidence_scope_detail": {
      "type": "object",
      "required": [
        "evidence_scope_ready",
        "required_benchmark_mode",
        "required_assertion_case_count",
        "required_runs_per_variant",
        "required_variants",
        "observed_benchmark_mode",
        "observed_assertion_case_count",
        "observed_variant_case_counts",
        "observed_min_runs_per_required_variant",
        "reason"
      ],
      "properties": {
        "evidence_scope_ready": {
          "type": "boolean"
        },
        "required_benchmark_mode": {
          "const": "ablation"
        },
        "required_assertion_case_count": {
          "type": "integer",
          "minimum": 1
        },
        "required_runs_per_variant": {
          "type": "integer",
          "minimum": 1
        },
        "required_variants": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "observed_benchmark_mode": {
          "enum": ["clean-paired", "ablation", "current-home-smoke"]
        },
        "observed_assertion_case_count": {
          "type": "integer",
          "minimum": 0
        },
        "observed_variant_case_counts": {
          "type": "object"
        },
        "observed_min_runs_per_required_variant": {
          "type": "integer",
          "minimum": 0
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "benchmark_mode": {
      "enum": ["clean-paired", "ablation", "current-home-smoke"]
    },
    "evidence_status": {
      "enum": ["pass", "partial", "fail", "not_collected"]
    },
    "effect_verdict": {
      "enum": ["inconclusive", "positive", "mixed", "neutral", "negative"]
    },
    "effect_status": {
      "enum": ["inconclusive", "improved", "mixed", "neutral", "regression"]
    },
    "effect_summary": {
      "type": "object"
    },
    "codex_home_policy": {
      "enum": ["isolated_only", "auth_borrowed_clean", "current_home_smoke_only", "mixed_or_unknown"]
    },
    "auth_policy": {
      "enum": ["isolated-api-key", "borrow-current", "current-home-full", "mixed"]
    },
    "codex_environment_policy": {
      "enum": ["isolated_api_key", "auth_borrowed_clean", "current_home_full", "mixed"]
    },
    "strict_benchmark_eligible": {
      "type": "boolean"
    },
    "run_id": {
      "type": "string"
    },
    "case_count": {
      "type": "integer"
    },
    "assertion_case_count": {
      "type": "integer"
    },
    "telemetry_only_case_count": {
      "type": "integer"
    },
    "result_count": {
      "type": "integer"
    },
    "benchmark_eligible_result_count": {
      "type": "integer"
    },
    "benchmark_passed_result_count": {
      "type": "integer"
    },
    "not_collected_grading_count": {
      "type": "integer"
    },
    "telemetry_only_result_count": {
      "type": "integer"
    },
    "contaminated_result_count": {
      "type": "integer"
    },
    "failure_categories": {
      "type": "object"
    },
    "setup_failure_reasons": {
      "type": "object"
    },
    "dominant_setup_failure_reason": {
      "enum": [
        "none",
        "missing_harness",
        "setup_script_missing",
        "setup_script_modified_bad_path",
        "dependency_install_failed",
        "python_compile_failed",
        "candidate_removed_required_file",
        "permission_denied",
        "shell_error",
        "unknown"
      ]
    },
    "setup_failure_subreasons": {
      "type": "object"
    },
    "dominant_setup_failure_subreason": {
      "enum": [
        "none",
        "candidate_modified_setup",
        "starter_fragile_path",
        "missing_env_root",
        "wrong_cwd",
        "missing_harness",
        "classifier_uncertain",
        "unknown"
      ]
    },
    "unknown_setup_failure_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "test_suite_failure_reasons": {
      "type": "object"
    },
    "security_failure_reasons": {
      "type": "object"
    },
    "current_home_result_count": {
      "type": "integer"
    },
    "current_home_full_result_count": {
      "type": "integer"
    },
    "user_skills_visible": {
      "type": "boolean"
    },
    "user_config_loaded": {
      "type": "boolean"
    },
    "user_rules_loaded": {
      "type": "boolean"
    },
    "ignore_user_config": {
      "type": "boolean"
    },
    "ignore_rules": {
      "type": "boolean"
    },
    "plugins_disabled": {
      "type": "boolean"
    },
    "variants": {
      "type": "object"
    },
    "delta": {
      "type": "object"
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cases_summary": {
      "type": "object"
    },
    "logging_summary": {
      "type": "object",
      "required": [
        "run_log_events",
        "timeline_events",
        "process_trace_count",
        "redaction_status",
        "redaction_error_count",
        "redaction_error_markers",
        "redaction_error_artifact_count",
        "redaction_error_artifacts",
        "redaction_error_artifacts_truncated",
        "max_event_size_bytes"
      ],
      "properties": {
        "run_log_events": {
          "type": "integer",
          "minimum": 0
        },
        "timeline_events": {
          "type": "integer",
          "minimum": 0
        },
        "process_trace_count": {
          "type": "integer",
          "minimum": 0
        },
        "redaction_status": {
          "enum": ["pass", "fail"]
        },
        "redaction_error_count": {
          "type": "integer",
          "minimum": 0
        },
        "redaction_error_markers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "redaction_error_artifact_count": {
          "type": "integer",
          "minimum": 0
        },
        "redaction_error_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "redaction_error_artifacts_truncated": {
          "type": "boolean"
        },
        "first_redaction_error_artifact": {
          "type": ["string", "null"]
        },
        "first_redaction_error_marker": {
          "type": ["string", "null"]
        },
        "first_redaction_error_excerpt_hash": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$"
        },
        "max_event_size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "process_compliance_summary": {
      "type": "object"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}
