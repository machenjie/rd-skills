{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://changeforge.local/schemas/codex-live-run-manifest.schema.json",
  "title": "Codex live benchmark run manifest",
  "type": "object",
  "required": [
    "schema_version",
    "generated_by",
    "run_id",
    "status",
    "benchmark_mode",
    "dry_run",
    "live_execution_allowed",
    "live_execution_effective",
    "cases",
    "variants",
    "runs_per_variant",
    "sandbox",
    "auth_policy",
    "codex_environment_policy",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "type": "integer"
    },
    "generated_by": {
      "const": "scripts/run-codex-live-benchmarks.py"
    },
    "run_id": {
      "type": "string"
    },
    "status": {
      "enum": ["not_collected", "skipped_not_opted_in", "partial", "collected", "failed"]
    },
    "benchmark_mode": {
      "enum": ["clean-paired", "ablation", "current-home-smoke"]
    },
    "dry_run": {
      "type": "boolean"
    },
    "live_execution_allowed": {
      "type": "boolean"
    },
    "live_execution_effective": {
      "type": "boolean"
    },
    "cases": {
      "type": "array"
    },
    "variants": {
      "type": "array"
    },
    "runs_per_variant": {
      "type": "integer"
    },
    "sandbox": {
      "enum": ["read-only", "workspace-write", "danger-full-access"]
    },
    "auth_policy": {
      "enum": ["isolated-api-key", "borrow-current", "current-home-full"]
    },
    "codex_environment_policy": {
      "enum": ["isolated_api_key", "auth_borrowed_clean", "current_home_full"]
    },
    "run_selection": {
      "type": "object"
    },
    "baseline_reuse_policy": {
      "enum": ["none", "diagnostic_only"]
    },
    "reused_baseline_run_id": {
      "type": ["string", "null"]
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}
