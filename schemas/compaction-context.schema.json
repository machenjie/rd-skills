{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://changeforge.local/schemas/compaction-context.schema.json",
  "title": "ChangeForge Compaction Context",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "snapshot_id",
    "snapshot_kind",
    "route_id",
    "selected_skills",
    "selected_capabilities",
    "required_quality_gates",
    "current_stage",
    "pdd_summary",
    "ddd_invariants",
    "sdd_decisions",
    "tdd_validation_plan",
    "changed_paths",
    "read_paths",
    "validation_results",
    "validation_freshness",
    "review_findings",
    "repair_events",
    "rereview_events",
    "residual_risk",
    "memory_references",
    "repo_graph_references",
    "active_skill_context",
    "last_material_edit_index",
    "last_validation_command_index",
    "privacy_redaction_status",
    "context_usable_status",
    "context_retention_status"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "snapshot_id": { "type": "string", "minLength": 1, "maxLength": 96 },
    "snapshot_kind": { "type": "string", "enum": ["pre_compact", "post_compact", "session_compact", "compact"] },
    "event_name": { "type": "string", "maxLength": 80 },
    "route_id": { "type": "string", "maxLength": 160 },
    "selected_skills": { "type": "array", "items": { "type": "string", "maxLength": 160 }, "maxItems": 20 },
    "selected_capabilities": { "type": "array", "items": { "type": "string", "maxLength": 160 }, "maxItems": 30 },
    "required_quality_gates": { "type": "array", "items": { "type": "string", "maxLength": 180 }, "maxItems": 20 },
    "current_stage": { "type": "string", "maxLength": 120 },
    "pdd_summary": { "type": "array", "items": { "type": "string", "maxLength": 240 }, "maxItems": 8 },
    "ddd_invariants": { "type": "array", "items": { "type": "string", "maxLength": 240 }, "maxItems": 10 },
    "sdd_decisions": { "type": "array", "items": { "type": "string", "maxLength": 240 }, "maxItems": 10 },
    "tdd_validation_plan": { "type": "array", "items": { "type": "string", "maxLength": 240 }, "maxItems": 10 },
    "changed_paths": { "type": "array", "items": { "type": "string", "maxLength": 200 }, "maxItems": 20 },
    "read_paths": { "type": "array", "items": { "type": "string", "maxLength": 200 }, "maxItems": 20 },
    "validation_results": { "type": "array", "items": { "type": "string", "maxLength": 240 }, "maxItems": 12 },
    "validation_freshness": { "type": "string", "maxLength": 160 },
    "review_findings": { "type": "array", "items": { "type": "string", "maxLength": 240 }, "maxItems": 12 },
    "repair_events": { "type": "array", "items": { "type": "string", "maxLength": 240 }, "maxItems": 12 },
    "rereview_events": { "type": "array", "items": { "type": "string", "maxLength": 240 }, "maxItems": 12 },
    "residual_risk": { "type": "array", "items": { "type": "string", "maxLength": 240 }, "maxItems": 10 },
    "memory_references": { "type": "array", "items": { "type": "string", "maxLength": 200 }, "maxItems": 10 },
    "repo_graph_references": { "type": "array", "items": { "type": "string", "maxLength": 200 }, "maxItems": 10 },
    "active_skill_context": { "type": "object", "additionalProperties": true, "maxProperties": 40 },
    "last_material_edit_index": { "type": "integer", "minimum": 0 },
    "last_validation_command_index": { "type": "integer", "minimum": 0 },
    "privacy_redaction_status": { "type": "string", "enum": ["pass", "fail"] },
    "context_usable_status": { "type": "string", "enum": ["pass", "fail"] },
    "context_retention_status": { "type": "string", "enum": ["pass", "partial", "fail"] },
    "missing_required_fields": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "redacted_required_fields": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "context_usable_fields": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "context_unusable_fields": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "warnings": { "type": "array", "items": { "type": "string", "maxLength": 200 }, "maxItems": 20 }
  }
}
